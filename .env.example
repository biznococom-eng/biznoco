# Supabase — lấy tại Project Settings → API → "Project URL" + "anon public key"
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Service Role Key — dùng cho admin operations (bypass RLS). Lấy tại Project Settings → API → service_role.
# KHÔNG bao giờ expose ra client-side!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# UUID của row trong bảng `accounts` để hiển thị mặc định trên dashboard.
# Lấy tại Supabase Studio → Table Editor → accounts → copy `id`.
# Nếu để trống, dashboard sẽ chạy ở chế độ MOCK với 12 ad demo.
NEXT_PUBLIC_DEMO_ACCOUNT_ID=00000000-0000-0000-0000-000000000001
